# MySQL Configuration
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=apotek_modern
MYSQL_USER=apotek_user
MYSQL_PASSWORD=apotek_pass
MYSQL_PORT=3306

# phpMyAdmin Configuration
PMA_PORT=8080

# Redis Configuration
REDIS_PORT=6379

# Adminer Configuration (optional)
ADMINER_PORT=8081

# Application Configuration
APP_NAME="Apotek Modern"
APP_ENV=production
APP_DEBUG=false
APP_TIMEZONE=Asia/Jakarta

# Mail Configuration (untuk reminder email)
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your-email@gmail.com
MAIL_PASSWORD=your-password
MAIL_ENCRYPTION=tls

# WhatsApp Gateway (untuk reminder WA)
WA_GATEWAY_URL=http://localhost:3000
WA_API_KEY=your-api-key

# BPJS Integration
BPJS_API_URL=https://apijkn.bpjs-kesehatan.go.id
BPJS_CONSUMER_ID=your-consumer-id
BPJS_SECRET_KEY=your-secret-key